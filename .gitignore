#
# Dotfiles (ignore all, whitelist specific)
#
.*
!.gitignore
!.github/

#
# Build output
#
build*/
cmake-build-*/
out/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
Makefile
*.ninja
.ninja_*

#
# Compiled objects and binaries
#
*.o
*.obj
*.so
*.dylib
*.exe
MP3Player

# Ignore .a files except pre-built FTXUI libs
*.a
!third_party/ftxui/lib/**/*.a

#
# Documentation (Claude-internal, not shipped)
#
ClaudeDocumentation/
docs/
*.md
!README.md

#
# Test build artifacts
#
third_party/catch2/
Testing/
CTestTestfile.cmake

#
# Scripts (internal dev tooling)
#
scripts/measure_memory.sh

#
# OS files
#
*~
\#*#
.DS_Store
Thumbs.db
